<launch>
  <!-- C-4.1.4 默认 PC 导航入口：地图 + AMCL + move_base/TEB。 -->

  <!-- 地图、速度输出和里程计链均可由 start_pc_full_navigation.sh 覆盖。 -->
  <arg name="map_file" default="$(find clbrobot)/maps/407-5.22-2120.yaml" />
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_frame_id" default="odom_lsm" />
  <arg name="odom_topic" default="/odom_lsm" />

  <!-- 发布静态地图 /map 和 /map_metadata。 -->
  <node pkg="map_server"
        name="map_server"
        type="map_server"
        args="$(arg map_file)"
        output="screen" />

  <!-- AMCL 输出 map -> odom_frame_id。 -->
  <include file="$(find clbrobot)/launch/amcl.launch">
    <arg name="odom_frame_id" value="$(arg odom_frame_id)" />
  </include>

  <!-- TEB 局部规划与两层 costmap。 -->
  <include file="$(find clbrobot)/param/navigation/move_base_teb.xml">
    <arg name="cmd_vel_topic" value="$(arg cmd_vel_topic)" />
    <arg name="local_odom_frame" value="$(arg odom_frame_id)" />
    <arg name="odom_topic" value="$(arg odom_topic)" />
  </include>
</launch>
