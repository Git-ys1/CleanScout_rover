<launch>
    <arg name="use_rviz" default="false" />
    <arg name="use_lidar" default="true" />
    <arg name="use_imu" default="true" />
    <arg name="use_base_bridge" default="true" />

    <group if="$(arg use_lidar)">
        <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
            <param name="serial_port" type="string" value="/dev/clblidar" />
            <param name="serial_baudrate" type="int" value="256000" />
            <param name="frame_id" type="string" value="laser" />
            <param name="inverted" type="bool" value="false" />
            <param name="angle_compensate" type="bool" value="true" />
            <param name="scan_mode" type="string" value="Sensitivity" />
            <param name="symmetry" type="bool" value="true" />
            <param name="shield_start_angle" type="int" value="0" />
            <param name="shield_end_angle" type="int" value="45" />
        </node>
    </group>

    <group if="$(arg use_imu)">
        <include file="$(find clbrobot)/launch/include/imu/mpu6050_chain.launch" />
    </group>

    <group if="$(arg use_base_bridge)">
        <node pkg="csrpi_base_bridge" type="wheel_bridge.py" name="csrpi_wheel_bridge" output="screen" respawn="false">
            <param name="port" value="/dev/csr_uno" />
            <param name="baudrate" value="115200" />
            <param name="send_rate_hz" value="20.0" />
        </node>

        <node pkg="csrpi_base_bridge" type="enc_to_raw_vel.py" name="csrpi_enc_to_raw_vel" output="screen" respawn="false" />

        <node pkg="clbrobot" name="clb_base_node" type="clb_base_node" output="screen">
            <param name="linear_scale" type="double" value="1.0" />
            <param name="low_battery" type="double" value="10.6" />
        </node>

        <node pkg="tf2_ros" type="static_transform_publisher" name="base_footprint_to_base_link" args="0 0 0 0 0 0 /base_footprint /base_link" />

        <node pkg="robot_localization" type="ekf_localization_node" name="ekf_localization" output="screen">
            <remap from="odometry/filtered" to="odom" />
            <rosparam command="load" file="$(find clbrobot)/param/ekf/robot_localization.yaml" />
        </node>
    </group>

    <group if="$(arg use_rviz)">
        <node pkg="rviz" type="rviz" name="rviz" output="screen" />
    </group>
</launch>
