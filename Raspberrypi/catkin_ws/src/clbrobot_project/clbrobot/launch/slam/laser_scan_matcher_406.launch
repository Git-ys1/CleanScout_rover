<launch>
  <arg name="scan_topic" default="/scan" />
  <arg name="imu_topic" default="/imu/data" />
  <arg name="odom_out_topic" default="/odom_lsm" />
  <arg name="pose_out_topic" default="/pose2D_lsm" />

  <arg name="fixed_frame" default="odom_lsm" />
  <arg name="base_frame" default="base_link" />
<node pkg="laser_scan_matcher"
        type="laser_scan_matcher_odom_node"
        name="laser_scan_matcher_odom"
        output="screen"
        clear_params="true">

    <param name="base_frame" value="$(arg base_frame)" />
    <param name="fixed_frame" value="$(arg fixed_frame)" />

    <param name="use_cloud_input" value="false" />
    <param name="use_imu" value="false" />
    <param name="use_odom" value="false" />
    <param name="use_alpha_beta" value="true" />

    <param name="publish_tf" value="true" />
    <param name="publish_pose" value="true" />
    <param name="publish_vel" value="true" />

    <param name="max_linear_correction" value="0.40" />
    <param name="max_angular_correction_deg" value="30.0" />
    <param name="max_iterations" value="10" />
    <param name="max_correspondence_dist" value="0.30" />
    <param name="sigma" value="0.010" />

    <param name="use_corr_tricks" value="1" />
    <param name="restart" value="0" />
    <param name="clustering_threshold" value="0.25" />
    <param name="orientation_neighbourhood" value="20" />
    <param name="use_point_to_line_distance" value="1" />
    <param name="outliers_maxPerc" value="0.90" />
    <param name="outliers_adaptive_order" value="0.70" />
    <param name="outliers_adaptive_mult" value="2.0" />
    <param name="outliers_remove_doubles" value="1" />

    <remap from="scan" to="$(arg scan_topic)" />
    <remap from="imu" to="$(arg imu_topic)" />
    <remap from="odom" to="$(arg odom_out_topic)" />
    <remap from="pose2D" to="$(arg pose_out_topic)" />
  </node>

</launch>
