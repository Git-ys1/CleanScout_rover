<launch>
  <arg name="enabled" default="false" />
  <arg name="url" default="wss://api.hzhhds.top/edge/ros" />
  <arg name="fallback_url" default="ws://192.168.8.222:3000/edge/ros" />
  <arg name="primary_failures_before_fallback" default="3" />
  <arg name="device_id" default="csrpi-001" />
  <arg name="device_token" default="" />
  <arg name="heartbeat_ms" default="5000" />
  <arg name="odom_hz" default="5" />
  <arg name="imu_hz" default="5" />
  <arg name="scan_hz" default="1" />
  <arg name="cmd_repeat_hz" default="50" />
  <arg name="default_hold_ms" default="1000" />
  <arg name="max_hold_ms" default="1500" />
  <arg name="toggle_motion_enabled" default="false" />
  <arg name="allow_manual_control" default="true" />
  <arg name="publish_cmd_vel" default="true" />
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="/odom_lsm" />
  <arg name="allow_fan_control" default="true" />
  <arg name="reconnect_delay_ms" default="1000" />

  <node if="$(arg enabled)" pkg="csrpi_edge_relay" type="edge_relay.py" name="edge_relay" output="screen">
    <param name="url" value="$(arg url)" />
    <param name="fallback_url" value="$(arg fallback_url)" />
    <param name="primary_failures_before_fallback" value="$(arg primary_failures_before_fallback)" />
    <param name="device_id" value="$(arg device_id)" />
    <param name="device_token" value="$(arg device_token)" />
    <param name="heartbeat_ms" value="$(arg heartbeat_ms)" />
    <param name="odom_hz" value="$(arg odom_hz)" />
    <param name="imu_hz" value="$(arg imu_hz)" />
    <param name="scan_hz" value="$(arg scan_hz)" />
    <param name="cmd_repeat_hz" value="$(arg cmd_repeat_hz)" />
    <param name="default_hold_ms" value="$(arg default_hold_ms)" />
    <param name="max_hold_ms" value="$(arg max_hold_ms)" />
    <param name="toggle_motion_enabled" value="$(arg toggle_motion_enabled)" />
    <param name="allow_manual_control" value="$(arg allow_manual_control)" />
    <param name="publish_cmd_vel" value="$(arg publish_cmd_vel)" />
    <param name="cmd_vel_topic" value="$(arg cmd_vel_topic)" />
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="allow_fan_control" value="$(arg allow_fan_control)" />
    <param name="reconnect_delay_ms" value="$(arg reconnect_delay_ms)" />
  </node>
</launch>
