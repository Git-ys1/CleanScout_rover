# backend 环境入口模板
#
# 请不要把这一份直接当成唯一部署模板使用。
# V-1.5.0 起，按场景选择 deploy/env 下的模板：
# - deploy/env/vline-backend.local-lan.env.example
# - deploy/env/vline-backend.public.env.example
# - deploy/env/vline-backend.public-edge.env.example
#
# local-lan：本机 H5 / 微信小程序本地调试 / 局域网 ROS 联调
# public：后续公网 H5 / admin web / 生产部署
# public-edge：云端 backend 接收树莓派 edge-relay 主动长连接
#
# /etc/vline-backend.env 仍属于部署环境文件，不直接入仓。

APP_PROFILE=local-lan
PORT=3000
DATABASE_URL="file:/var/lib/vline-backend/dev.db"
JWT_SECRET="replace-with-a-random-string-at-least-32-chars"
JWT_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_API_MODE=chat
OPENCLAW_MODEL=openclaw/default
OPENCLAW_BEARER_TOKEN=
OPENCLAW_REQUEST_TIMEOUT_MS=30000
ROS_ENABLED=true
ROS_TRANSPORT=mock
ROSBRIDGE_URL=ws://127.0.0.1:9090
ROS_CMD_VEL_TOPIC=/cmd_vel
ROS_ODOM_TOPIC=/odom
ROS_IMU_TOPIC=/imu/data
ROS_SCAN_TOPIC=/scan
ROS_CMD_REPEAT_HZ=10
ROS_CMD_DEFAULT_HOLD_MS=400
ROS_RECONNECT_DELAY_MS=1000
EDGE_RELAY_ENABLED=false
EDGE_RELAY_PATH=/edge/ros
EDGE_DEVICE_AUTH_REQUIRED=true
EDGE_HELLO_TIMEOUT_MS=5000
EDGE_HEARTBEAT_TIMEOUT_MS=15000
EDGE_SERVER_PING_INTERVAL_MS=25000
EDGE_ALLOWED_DEVICE_IDS=
EDGE_DEVICE_BOOTSTRAP_ID=
EDGE_DEVICE_BOOTSTRAP_TOKEN=
