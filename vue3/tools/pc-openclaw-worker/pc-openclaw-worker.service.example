[Unit]
Description=CleanScout PC OpenClaw Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/yusu/Work/CleanScout_rover/tools/pc-openclaw-worker
EnvironmentFile=/home/yusu/Work/CleanScout_rover/tools/pc-openclaw-worker/.env
ExecStart=/usr/bin/node src/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
