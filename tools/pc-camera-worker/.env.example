CAMERA_WORKER_ENABLED=true

DEVICE_ID=pc-001
CAMERA_ID=openmv-arm-cam-001

CAMERA_SOURCE_URL=http://ESP32-CAM-IP:81/stream
CAMERA_MODE=mjpeg
CAMERA_FRAMESIZE=7
CAMERA_HMIRROR=1
CAMERA_VFLIP=1
CAMERA_TARGET_FPS=8
CAMERA_MAX_FRAME_BYTES=200000
CAMERA_CONNECT_TIMEOUT_MS=3000
CAMERA_READ_TIMEOUT_MS=0

CAMERA_CLOUD_WS=wss://api.hzhhds.top/edge/camera
CAMERA_CLOUD_TOKEN=replace-with-camera-ingest-token

CAMERA_LOG_LEVEL=info
CAMERA_RECONNECT_DELAY_MS=2000
