CAMERA_WORKER_ENABLED=true

DEVICE_ID=pc-001
CAMERA_ID=openmv-arm-cam-001

CAMERA_SOURCE_URL=
CAMERA_SOURCE_HOST_SUFFIX=91
CAMERA_SOURCE_PORT=81
CAMERA_SOURCE_PATH=/stream
CAMERA_MODE=mjpeg
CAMERA_UPLINK_MODE=raw-mjpeg
CAMERA_FRAMESIZE=7
CAMERA_HMIRROR=1
CAMERA_VFLIP=1
CAMERA_TARGET_FPS=20
CAMERA_MAX_FRAME_BYTES=500000
CAMERA_MAX_CLOUD_BUFFERED_BYTES=2097152
CAMERA_CONNECT_TIMEOUT_MS=3000
CAMERA_READ_TIMEOUT_MS=0

CAMERA_CLOUD_WS=wss://api.hzhhds.top/edge/camera
CAMERA_CLOUD_TOKEN=replace-with-camera-ingest-token

CAMERA_LOG_LEVEL=info
CAMERA_RECONNECT_DELAY_MS=2000
